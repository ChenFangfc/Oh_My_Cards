{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Oh My Cards",
  "version": "0.1.0",
  "identifier": "com.ohmycard.desktop",
  "build": {
    "beforeDevCommand": "PORT=19953 BASE_PATH=/ pnpm run dev",
    "devUrl": "http://localhost:19953",
    "beforeBuildCommand": "PORT=19953 BASE_PATH=/ pnpm run build",
    "frontendDist": "../dist/public"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Oh My Cards",
        "width": 1200,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Finance",
    "shortDescription": "Local-first credit card optimizer",
    "longDescription": "Oh My Cards keeps wallet and spending data on the user's Mac while downloading public card rule updates.",
    "macOS": {
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 420
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY",
      "endpoints": [
        "https://updates.ohmycard.app/latest.json"
      ]
    }
  }
}
